{
  "name": "domio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "dev:server": "node --env-file-if-exists=.env.development node_modules/next/dist/bin/next dev",
    "build:development": "node --env-file=.env.development node_modules/next/dist/bin/next build",
    "start:development": "node --env-file=.env.development node_modules/next/dist/bin/next start",
    "build:production": "node --env-file=.env.production node_modules/next/dist/bin/next build",
    "start:production": "node --env-file=.env.production node_modules/next/dist/bin/next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:contract": "vitest run tests/contract --passWithNoTests",
    "test:contract:update": "CONTRACT_UPDATE_SNAPSHOTS=true vitest run tests/contract --passWithNoTests",
    "worker:emails": "tsx scripts/worker-emails.ts",
    "check:services": "tsx scripts/check-services.ts",
    "db:generate": "drizzle-kit generate --config=src/infrastructure/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/infrastructure/db/drizzle.config.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio --config=src/infrastructure/db/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=src/infrastructure/db/drizzle.config.ts",
    "quality": "pnpm lint && pnpm typecheck && pnpm test:run",
    "verify": "pnpm quality && pnpm test:contract && pnpm test:e2e && pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.64.0",
    "@upstash/redis": "^1.38.0",
    "drizzle-orm": "^0.45.2",
    "maplibre-gl": "^5.24.0",
    "next": "15.5.20",
    "next-auth": "^4.24.14",
    "pg": "^8.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.17.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^3.2.0",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-zod": "^0.8.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^3.2.0"
  }
}
