# ---------------------------------------------------------------------------
# Base template. Copy to the file for your target environment and fill in:
#   .env.local        → your machine        (APP_ENV=local)
#   .env.development  → dev/staging server  (APP_ENV=development)
#   .env.production   → production           (APP_ENV=production)
# See ENVIRONMENTS.md for how each file is loaded.
# ---------------------------------------------------------------------------

# Semantic environment: local | development | production.
# Drives image serving (local placeholders vs R2) and other per-env behaviour.
APP_ENV=local
# Same value, exposed to the client bundle (must match APP_ENV).
NEXT_PUBLIC_APP_ENV=local

# Neon PostgreSQL connection string (development branch)
DATABASE_URL=postgresql://user:password@localhost:5432/domio

# Public tenant ID — UUID of the single active commercial tenant used by the public site (domio.com)
PUBLIC_TENANT_ID=<your-public-tenant-uuid-here>

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=<your-auth-secret-here>

# Public URL of the app in development
AUTH_URL=http://localhost:3000

# Cloudflare R2 account ID
R2_ACCOUNT_ID=<your-r2-account-id-here>

# Cloudflare R2 access key ID
R2_ACCESS_KEY_ID=<your-r2-access-key-id-here>

# Cloudflare R2 secret access key
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key-here>

# Cloudflare R2 bucket name (development)
R2_BUCKET=<your-r2-bucket-here>

# Public URL for R2 bucket (CDN / public access)
R2_PUBLIC_URL=<your-r2-public-url-here>

# Resend API key (test mode)
RESEND_API_KEY=<your-resend-api-key-here>

# Sentry DSN for the development environment
SENTRY_DSN=<your-sentry-dsn-here>

# Upstash / Vercel KV URL for rate-limiting counters
RATE_LIMIT_STORE_URL=<your-rate-limit-store-url-here>

# Cloudflare Turnstile site key (public, exposed to client)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<your-turnstile-site-key-here>

# Cloudflare Turnstile secret key (server-side verification)
TURNSTILE_SECRET_KEY=<your-turnstile-secret-key-here>

# Public base URL of the site (used for canonical URLs, sitemap, OG images, robots.txt Sitemap directive)
# No trailing slash. In development this defaults to http://localhost:3000 if not set.
# Examples: https://domio.com (production), https://preview-abc123.domio.pages.dev (preview)
NEXT_PUBLIC_SITE_URL=<your-site-url-here>
