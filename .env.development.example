# ---------------------------------------------------------------------------
# DEVELOPMENT / STAGING SERVER template.
# Copy to `.env.development` (gitignored) and fill in real values.
# Loaded by: pnpm build:development / start:development / dev:server
# On a hosting platform, set these as platform env vars instead of a file.
# ---------------------------------------------------------------------------

APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Postgres for the dev server (e.g. Neon development branch)
DATABASE_URL=postgresql://user:password@dev-host:5432/domio

PUBLIC_TENANT_ID=<dev-public-tenant-uuid>

AUTH_SECRET=<dev-auth-secret>
AUTH_URL=https://dev.domio.example

# Cloudflare R2 — DEV bucket. Unlike local, images are served from R2 here.
R2_ACCOUNT_ID=<dev-r2-account-id>
R2_ACCESS_KEY_ID=<dev-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<dev-r2-secret-access-key>
R2_BUCKET=domio-dev
R2_PUBLIC_URL=https://dev-cdn.domio.example

RESEND_API_KEY=<dev-resend-api-key>
SENTRY_DSN=<dev-sentry-dsn>
RATE_LIMIT_STORE_URL=<dev-rate-limit-store-url>

# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://dev.domio.example
