# ---------------------------------------------------------------------------
# PRODUCTION template.
# Copy to `.env.production` (gitignored) and fill in real values.
# Loaded by: pnpm build:production / start:production
# On a hosting platform, set these as platform env vars instead of a file.
# ---------------------------------------------------------------------------

APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

# Postgres for production
DATABASE_URL=postgresql://user:password@prod-host:5432/domio

PUBLIC_TENANT_ID=<prod-public-tenant-uuid>

AUTH_SECRET=<prod-auth-secret>
AUTH_URL=https://domio.com

# Cloudflare R2 — PRODUCTION bucket.
R2_ACCOUNT_ID=<prod-r2-account-id>
R2_ACCESS_KEY_ID=<prod-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<prod-r2-secret-access-key>
R2_BUCKET=domio-prod
R2_PUBLIC_URL=https://cdn.domio.com

RESEND_API_KEY=<prod-resend-api-key>
SENTRY_DSN=<prod-sentry-dsn>
RATE_LIMIT_STORE_URL=<prod-rate-limit-store-url>

# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://domio.com
